---
import { getCollection } from "astro:content";
import SiteLayout from "../layouts/SiteLayout.astro";
import { toPostSummary } from "../data/posts";

const posts = (await getCollection("posts"))
  .map(toPostSummary)
  .sort((a, b) => b.date.getTime() - a.date.getTime());
const latestPosts = posts.slice(0, 3);

const description = "Recent posts by Juan Turk.";

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
---

<SiteLayout title="Juan Turk" description={description}>
  <section aria-labelledby="about-me" class="space-y-6 py-8">
    <h1 class="text-5xl font-[750] leading-none tracking-[-0.05em] text-white sm:text-7xl">
      Hey, I'm Juan Turk!
    </h1>
    <p class="text-lg leading-8 text-zinc-300 sm:text-xl">
      After 15+ years of building software across the stack and every stage of the development process, I always try to create simple solutions that are reliable, fail-safe, and have a true reason for existing. <br /> Lately, my curiosity has shifted toward automation, AI, and developing better software tools.
    </p>
  </section>
  
  <section aria-labelledby="recent-posts" class="py-6 sm:py-8">
    <div>
      <h3 id="recent-posts" class="text-3xl font-[760] tracking-[-0.05em] text-white sm:text-4xl">
        Check my recent blog posts
      </h3>
    </div>

    <div class="mt-10 grid gap-x-10 gap-y-12 lg:grid-cols-3">
      {latestPosts.map((post) => (
        <article class="space-y-4">
          <p class="text-sm text-zinc-500">
            <time datetime={post.date.toISOString()}>{formatDate(post.date)}</time>
          </p>
          <h3 class="mt-4 text-2xl font-[720] leading-tight tracking-[-0.04em] text-white">
            <a class="transition hover:text-zinc-200" href={`/blog/${post.slug}/`}>
              {post.title}
            </a>
          </h3>
          <p class="mt-4 text-base leading-7 text-zinc-400">{post.description}</p>
        </article>
      ))}
    </div>
  </section>
</SiteLayout>
