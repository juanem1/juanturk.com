---
import { getCollection } from "astro:content";
import SiteLayout from "../layouts/SiteLayout.astro";
import { toPostSummary } from "../data/posts";

const posts = (await getCollection("posts"))
  .map(toPostSummary)
  .sort((a, b) => b.date.getTime() - a.date.getTime());
const latestPosts = posts.slice(0, 3);

const description = "Recent posts by Juan Turk.";

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
---

<SiteLayout title="Juan Turk" description={description}>
  <section aria-labelledby="about-me" class="px-5 py-10 sm:px-8 sm:py-12 lg:px-10">
    <div class="space-y-6 lg:w-2/3">
      <h1
        id="about-me"
        class="text-4xl font-[750] leading-[0.92] text-white sm:text-6xl lg:text-7xl"
      >
        Hey, I&apos;m Juan Turk!
      </h1>
      <div class="space-y-4 leading-7 text-zinc-300 sm:text-lg sm:leading-8 lg:text-xl">
        <p>
          After 15+ years of building software across the stack and every stage of the development
          process, I always try to create simple solutions that are reliable, fail-safe, and have
          a true reason for existing.
        </p>
        <p>
          Lately, my curiosity has shifted toward automation, AI, and developing better software
          tools.
        </p>
      </div>
    </div>
  </section>

  <section aria-labelledby="recent-posts" class="px-5 py-8 sm:px-8 sm:py-10 lg:px-10">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-2xl space-y-3">
        <h2 id="recent-posts" class="text-3xl font-[760] tracking-[-0.05em] text-white sm:text-4xl">
          Check my recent blog posts
        </h2>
        <p class="leading-7 text-zinc-400">
          Check my latest posts and explore the ideas, lessons, and experiments I keep publishing over time.
        </p>
      </div>

      <a
        href="/blog/"
        class="interactive-chip inline-flex items-center justify-center self-start rounded-full border border-white/15 px-4 py-2.5 text-sm font-semibold text-white transition hover:border-white/30 hover:bg-white/10"
      >
        Browse all posts
      </a>
    </div>

    <div class="mt-8 grid gap-y-8 sm:mt-10 lg:grid-cols-[minmax(0,1fr)_3rem_minmax(0,1fr)_3rem_minmax(0,1fr)]">
      {latestPosts.map((post, index) => (
        <div class="group contents">
          {index > 0 && (
            <div
              aria-hidden="true"
              class="hidden w-px justify-self-center self-stretch bg-white/10 transition-colors duration-300 group-hover:bg-orange-300/35 lg:block"
            />
          )}

          <a
            href={`/blog/${post.slug}/`}
            class:list={[
              "relative -mx-4 flex h-full flex-col rounded-[1.75rem] px-4 py-4 transition-all duration-300 ease-out group-hover:-translate-y-1",
              index > 0 ? "border-t border-white/10 pt-8 lg:border-t-0 lg:pt-4" : "",
            ]}
          >
            <p class="text-sm text-zinc-500 transition-colors duration-300 group-hover:text-zinc-400">
              <time datetime={post.date.toISOString()}>{formatDate(post.date)}</time>
            </p>
            <h3 class="mt-4 text-xl font-[720] leading-tight tracking-[-0.04em] text-white transition-colors duration-300 group-hover:text-zinc-200 sm:text-2xl">
              {post.title}
            </h3>
            <p class="mt-4 leading-7 text-zinc-400 transition-colors duration-300 group-hover:text-zinc-300">
              {post.description}
            </p>
            <div class="mt-auto pt-6">
              <span class="inline-flex items-center text-sm font-semibold text-orange-300 transition duration-300 group-hover:text-orange-200">
                Read post
              </span>
            </div>
          </a>
        </div>
      ))}
    </div>
  </section>
</SiteLayout>
