---
import { getCollection } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";
import { toPostSummary } from "../../data/posts";

const posts = (await getCollection("posts"))
  .map(toPostSummary)
  .sort((a, b) => b.date.getTime() - a.date.getTime());
const postsByYear = Object.entries(
  posts.reduce<Record<string, typeof posts>>((groups, post) => {
    const year = String(post.date.getFullYear());
    groups[year] ??= [];
    groups[year].push(post);
    return groups;
  }, {})
).sort(([yearA], [yearB]) => Number(yearB) - Number(yearA));
---

<BlogLayout title="Archive | Juan Turk" description="List of published blog posts">
  <section class="space-y-5 pb-12 pt-8 px-5 lg:px-10">
    <h1 class="text-5xl font-[780] tracking-[-0.06em] text-white sm:text-7xl">
      The Archive
    </h1>
    <p class="max-w-3xl text-lg leading-8 text-zinc-300 sm:text-xl">
      Everything I've written so far.
    </p>
  </section>

  <div class="space-y-16 px-5 lg:px-10">
    {postsByYear.map(([year, yearPosts], yearIndex) => (
      <section
        aria-labelledby={`year-${year}`}
        class:list={[yearIndex === postsByYear.length - 1 && "mb-12"]}
      >
        <div class="flex items-center border-b border-white/8 pb-5">
          <h2 id={`year-${year}`} class="mr-4 text-4xl font-[780] tracking-[-0.05em] text-white lg:top-28">
            {year}
          </h2>
          <span class="rounded-full border border-white/10 px-3 py-1 text-sm text-zinc-400">
            {yearPosts.length} {yearPosts.length === 1 ? "post" : "posts"}
          </span>
        </div>

        <ol>
          {yearPosts.map((post, postIndex) => (
            <li
              class:list={[
                "py-5",
                postIndex !== yearPosts.length - 1 && "border-b border-white/8",
              ]}
            >
              <article class="grid items-start gap-1 sm:grid-cols-[10rem_minmax(0,1fr)] sm:gap-2">
                <p class="text-zinc-500">
                  <time datetime={post.date.toISOString()}>
                    {post.date.toLocaleDateString("en-US", {
                      day: "numeric",
                      month: "long",
                    })}
                  </time>
                </p>

                <div class="min-w-0">
                  <h3 class="text-2xl font-bold tracking-[-0.035em] text-white sm:text-3xl">
                    <a class="transition hover:text-zinc-300" href={`/blog/${post.slug}/`}>
                      {post.title}
                    </a>
                  </h3>
                  <p class="mt-2 max-w-3xl truncate text-lg leading-8 text-zinc-400">
                    {post.subtitle}
                  </p>
                </div>
              </article>
            </li>
          ))}
        </ol>
      </section>
    ))}
  </div>
</BlogLayout>
