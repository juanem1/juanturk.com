---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import PostTags from "../../components/PostTags.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { toPostSummary } from "../../data/posts";

const posts = (await getCollection("posts"))
  .map(toPostSummary)
  .sort((a, b) => b.date.getTime() - a.date.getTime());
const featuredPosts = posts.filter((post) => post.featured);
const postsForHome = [...featuredPosts, ...posts.filter((post) => !post.featured)].slice(0, 4);
const [leadPost, ...secondaryPosts] = postsForHome;

const description =
  "I write about software development, remote culture, and the messy behind-the-scenes of building products. No corporate fluff, just firsthand experience.";

const formatDate = (date: Date) =>
  date.toLocaleDateString("en-US", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
---

<BaseLayout title="Blog | Juan Turk" description={description}>
  <section class="space-y-6 py-8">
    <h1 class="text-5xl font-[750] leading-none tracking-[-0.05em] text-white sm:text-7xl">
      Engineering, in the real world
    </h1>
    <p class="text-lg leading-8 text-zinc-300 sm:text-xl">{description}</p>
  </section>

  <section aria-labelledby="featured-posts" class="space-y-6">
    <div class="flex items-center justify-between gap-4">
      <h2 id="featured-posts" class="text-2xl font-[650] tracking-[-0.03em] text-white">
        Featured posts
      </h2>
      <a class="text-sm font-medium text-zinc-300 transition hover:text-white" href="/blog/archive/">
        View archive
      </a>
    </div>

    {leadPost && (
      <div class="grid gap-6 xl:grid-cols-2">
        <article class="group">
          <a class="block" href={`/blog/${leadPost.slug}/`}>
            {leadPost.heroImage && (
              <div class="overflow-hidden rounded-2xl border border-white/10">
                <Image
                  src={leadPost.heroImage}
                  alt={leadPost.title}
                  class="aspect-16/10 h-full w-full object-cover"
                  widths={[900, 1200, 1600]}
                  sizes="(min-width: 1280px) 50vw, 100vw"
                  format="webp"
                  loading="eager"
                />
              </div>
            )}
          </a>

          <div class="mt-6">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-emerald-300/90">
              <PostTags max={2} tags={leadPost.tags} />
            </p>
            <h3 class="mt-4 max-w-4xl text-5xl font-[760] leading-[0.95] tracking-[-0.055em] text-white">
              <a class="transition group-hover:text-zinc-200" href={`/blog/${leadPost.slug}/`}>
                {leadPost.title}
              </a>
            </h3>
            <p class="mt-5 max-w-3xl text-lg leading-8 text-zinc-200 sm:text-xl">
              {leadPost.description}
            </p>

            <div class="mt-8 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-white">
              <time datetime={leadPost.date.toISOString()}>{formatDate(leadPost.date)}</time>
            </div>
          </div>
        </article>

        {secondaryPosts.length > 0 && (
          <ul>
            {secondaryPosts.map((post, index) => (
              <li class:list={["border-white/10 pb-4 sm:pb-5", index > 0 ? "border-t pt-4 sm:pt-5" : "pt-0"]}>
                <article class="group grid gap-5 md:grid-cols-[168px_minmax(0,1fr)] md:items-start">
                  <a class="block" href={`/blog/${post.slug}/`}>
                    {post.heroImage && (
                      <div class="overflow-hidden rounded-xl border border-white/10">
                        <Image
                          src={post.heroImage}
                          alt={post.title}
                          class="aspect-square h-full w-full object-cover"
                          widths={[336, 512, 768]}
                          sizes="(min-width: 768px) 168px, 40vw"
                          format="webp"
                          loading="eager"
                        />
                      </div>
                    )}
                  </a>

                  <div class="min-w-0">
                    <p class="text-xs font-semibold uppercase tracking-[0.16em] text-fuchsia-300 sm:text-sm">
                      <PostTags max={2} tags={post.tags} compact />
                    </p>
                    <h3 class="mt-3 text-2xl font-bold leading-tight tracking-[-0.04em] text-white">
                      <a class="transition group-hover:text-zinc-200" href={`/blog/${post.slug}/`}>
                        {post.title}
                      </a>
                    </h3>
                    <p class="mt-3 text-base text-zinc-400">
                      {post.description}
                    </p>
                    <div class="mt-5 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-white">
                      <time datetime={post.date.toISOString()}>{formatDate(post.date)}</time>
                    </div>
                  </div>
                </article>
              </li>
            ))}
          </ul>
        )}
      </div>
    )}
  </section>
</BaseLayout>
