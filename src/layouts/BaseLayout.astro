---
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import globalStylesHref from "../styles/global.css?url";

interface Props {
  title: string;
  description?: string;
  ogType?: "website" | "article";
  ogImage?: string;
  bodyClass?: string;
  htmlClass?: string;
  mainClass?: string;
}

const {
  title,
  description = "Blog estatico personal",
  ogType = "website",
  ogImage,
  bodyClass = "min-h-screen text-zinc-100 antialiased",
  htmlClass = "bg-fixed bg-[linear-gradient(180deg,#1c2128,#22272e,#0d1117)]",
  mainClass = "mx-auto w-full max-w-6xl pb-10",
} = Astro.props;
const currentYear = new Date().getFullYear();
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).href;
---

<html
  lang="es"
  transition:name="root"
  transition:animate="none"
  class={htmlClass}
>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <Font cssVariable="--font-mona-sans" preload />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link rel="preload" href={globalStylesHref} as="style" />
    <link rel="stylesheet" href={globalStylesHref} media="print" onload="this.media='all'" />
    <noscript>
      <link rel="stylesheet" href={globalStylesHref} />
    </noscript>
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class={bodyClass}>
    <slot name="header" />

    <main transition:animate="fade" class={mainClass}>
      <slot />
    </main>

    <footer class="mx-auto max-w-6xl border-t border-white/8 px-5 py-8 text-center text-sm text-zinc-500 sm:px-8 lg:px-10">
      <p>&copy; Juan Turk · 2023 - {currentYear}</p>
      <p class="mt-2">
        Opinions are my own. Just a developer sharing lessons learned from 20 years of shipping code and navigating the tech industry.
      </p>
    </footer>
  </body>
</html>
