---
interface Props {
  authorName: string;
  authorHandle: string;
  avatarUrl: string;
  minutesRead: string;
  date: Date;
  postTitle: string;
  postUrl: string;
}
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

const { authorName, authorHandle, avatarUrl, minutesRead, date, postTitle, postUrl } = Astro.props;
const encodedPostUrl = encodeURIComponent(postUrl);
const encodedPostTitle = encodeURIComponent(postTitle);
const shareLinks = [
  {
    href: `https://www.facebook.com/sharer/sharer.php?u=${encodedPostUrl}`,
    icon: 'fb',
    label: 'Share on Facebook',
  },
  {
    href: `https://www.linkedin.com/shareArticle?mini=true&url=${encodedPostUrl}`,
    icon: 'in',
    label: 'Share on LinkedIn',
  },
  {
    href: `https://x.com/share?text=${encodedPostTitle}&url=${encodedPostUrl}`,
    icon: 'x',
    label: 'Share on X',
  },
];
---

<div class="mb-8 flex flex-wrap items-center gap-4 border-t border-b border-white/10 p-4 text-zinc-400">
  <Image src={avatarUrl}
    alt={`Avatar of ${authorName} on GitHub`}
    class="h-14 w-14 rounded-full border border-white/10 object-cover"
    width="56"
    height="56"
    loading="lazy"
  />
  <div class="flex min-w-0 flex-col">
    <span class="font-[650] text-white">{authorName}</span>
    <span class="text-sm text-zinc-400">{authorHandle}</span>
  </div>
  <div class="h-8 w-px bg-white/10"></div>
  <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
    <p class="text-sm font-medium text-zinc-400">{minutesRead}</p>
    <span class="text-zinc-500">·</span>
    <time class="text-sm font-medium text-zinc-400" datetime={date.toISOString()}>
      {date.toLocaleDateString("en-US", { day: "numeric", month: "short", year: "numeric" })}
    </time>
  </div>
  <div class="ml-auto flex items-center gap-3">
    {shareLinks.map(({ href, icon, label }) => (
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={label}
        title={label}
        class="flex h-9 w-9 items-center justify-center rounded-full border border-white/10 text-zinc-400 transition hover:border-white/20 hover:text-white"
      >
        <Icon name={icon} class="h-4 w-4" />
      </a>
    ))}
  </div>
</div>
