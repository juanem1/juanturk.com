---
import { Icon } from "astro-icon/components";
---

<header
  transition:persist
  class="sticky top-0 z-50 border-b border-white/15 bg-[linear-gradient(to_bottom,#0d1117fa,#161b22f7,#1c2128f2)] backdrop-blur-md"
>
  <nav
    aria-label="Principal"
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-4 sm:px-8 lg:px-10"
  >
    <a href="/" class="shrink-0 font-[650] tracking-[-0.02em] text-white transition hover:text-zinc-200 sm:text-lg">
      Juan Turk
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      <a
        href="/blog/"
        class="inline-flex items-center rounded-full border border-transparent bg-transparent px-3 py-2 text-sm font-semibold text-zinc-100 transition hover:border-white/30 hover:bg-white/10 hover:text-white sm:px-4"
      >
        Blog
      </a>
      <a
        href="https://github.com/juanem1"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub profile"
        title="GitHub"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full text-zinc-300 transition hover:bg-white/10 hover:text-white"
      >
        <Icon name="gh" class="h-5 w-5" />
      </a>
      <a
        href="https://www.linkedin.com/in/juanemilioturk/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn profile"
        title="LinkedIn"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full text-zinc-300 transition hover:bg-white/10 hover:text-white"
      >
        <Icon name="in" class="h-5 w-5" />
      </a>
    </div>
  </nav>
</header>
